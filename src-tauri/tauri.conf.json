{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Triviacon",
  "version": "0.9.4",
  "identifier": "io.github.triviacon.triviacon",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm gen:icons && pnpm dev:web",
    "beforeBuildCommand": "pnpm gen:icons && pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "control-panel",
        "title": "TriviaCON — Control Panel",
        "url": "src/renderer/control-panel/index.html",
        "width": 1600,
        "height": 1000,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPLOCALDATA/**",
            "$APPDATA/**",
            "$APPCACHE/**",
            "$APPCONFIG/**",
            "$TEMP/**",
            "$HOME/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
